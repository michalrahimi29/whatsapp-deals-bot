# WhatsApp Deals Bot - Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key (change this in production!)
SECRET_KEY=your-secret-key-here

# Twilio credentials (for WhatsApp integration)
# Get these from https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Web base URL (used in WhatsApp messages to link to the web UI)
# For Render: https://your-app-name.onrender.com
# For local: http://localhost:5000
WEB_BASE_URL=http://localhost:5000

# Server port
PORT=5000

# Debug mode (set to 0 in production)
FLASK_DEBUG=1
